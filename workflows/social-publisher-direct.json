            { "name": "x-api-key", "value": "={{$env.ANTHROPIC_API_KEY}}" },
            { "name": "anthropic-version", "value": "2023-06-01" },
            { "name": "content-type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ \"model\": \"claude-sonnet-4-20250514\", \"max_tokens\": 1024, \"system\": \"Convert blog post into 150-300 word LinkedIn post for SeedLink CEO Shilpa Kollengode. Structure: Hook line, Insight (3-5 short paragraphs), Takeaway, CTA to blog, Hashtags. Voice: founder sharing observations, first person, direct, opinionated. No corporate speak.\", \"messages\": [{ \"role\": \"user\", \"content\": \"Convert this blog post into a LinkedIn post:\\n\\nTitle: \" + $json.blogTitle + \"\\nURL: \" + $json.blogUrl + \"\\n\\nContent:\\n\" + $json.blogContent.substring(0, 6000) }] }) }}",
        "options": {
          "response": { "response": { "responseFormat": "json" } },
          "timeout": 60000,
          "retry": { "maxRetries": 3, "retryInterval": 2000 }
        }
      }
    },
