    {
      "id": "wl-code-thread-publisher",
      "name": "Code: Twitter Thread Publisher",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1800, 920],
      "parameters": {
        "jsCode": "// Twitter Thread Publisher\n// Publishes a thread by chaining tweets with in_reply_to_tweet_id\n// Input: $json.Content should be a JSON array of tweet strings, or a single tweet string\n\nconst content = $json.Content;\nlet tweets = [];\n\ntry {\n  tweets = JSON.parse(content);\n} catch (e) {\n  // Single tweet, not a thread\n  tweets = [content];\n}\n\nif (!Array.isArray(tweets) || tweets.length <= 1) {\n  // Single tweet already published by the previous node\n  return [{ json: { status: 'published', type: 'single_tweet', tweetId: $json.data?.id || 'unknown' } }];\n}\n\n// For threads, the first tweet was already published.\n// We need to publish replies 2-N chained to the first tweet's ID.\nconst firstTweetId = $json.data?.id;\n\nif (!firstTweetId) {\n  return [{ json: { status: 'error', message: 'First tweet ID not found in response. Thread cannot continue.' } }];\n}\n\nconst results = [{ tweet: tweets[0], tweetId: firstTweetId, status: 'published' }];\nlet lastTweetId = firstTweetId;\n\nfor (let i = 1; i < tweets.length; i++) {\n  try {\n    const response = await this.helpers.httpRequest({\n      method: 'POST',\n      url: 'https://api.twitter.com/2/tweets',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({\n        text: tweets[i],\n        reply: { in_reply_to_tweet_id: lastTweetId }\n      }),\n      timeout: 30000\n    });\n\n    const replyId = response?.data?.id || 'unknown';\n    results.push({ tweet: tweets[i], tweetId: replyId, status: 'published' });\n    lastTweetId = replyId;\n  } catch (err) {\n    results.push({ tweet: tweets[i], status: 'failed', error: err.message });\n    break; // Stop thread on failure\n  }\n\n  // Rate limit courtesy delay (1 second between tweets)\n  await new Promise(resolve => setTimeout(resolve, 1000));\n}\n\nreturn [{ json: { status: 'thread_published', threadLength: results.length, tweets: results } }];"
      }
    },
